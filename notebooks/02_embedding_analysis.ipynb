 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 🔢 Embedding Space Analysis\n",
    "Visualizing the FAISS embedding space using UMAP dimensionality reduction to understand how chunks cluster by topic and document."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "metadata": {},
   "outputs": [
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "INFO:src.embeddings.vector_store:Loading embedding model: BAAI/bge-base-en-v1.5\n",
      "INFO:sentence_transformers.SentenceTransformer:Load pretrained SentenceTransformer: BAAI/bge-base-en-v1.5\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "path_to_your_project_directory",
      "Loading data...\n"
     ]
    },
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "INFO:src.ingestion.pdf_loader:Loaded 1050 pages from faa_airframe\n",
      "INFO:src.ingestion.pdf_loader:Loaded 674 pages from faa_general\n",
      "INFO:src.ingestion.pdf_loader:Loaded 499 pages from faa_powerplant\n",
      "INFO:src.ingestion.pdf_loader:Total pages loaded: 2223\n",
      "INFO:src.ingestion.chunker:Created 18223 chunks from 2223 pages\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Loaded 18223 chunks\n"
     ]
    }
   ],
   "source": [
    "import os\n",
    "import sys\n",
    "\n",
    "# Directly set to your project root\n",
    "PROJECT_ROOT = r\"path_to_your_root"\n",
    "os.chdir(PROJECT_ROOT)\n",
    "sys.path.insert(0, PROJECT_ROOT)\n",
    "print(os.getcwd())\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from tqdm.auto import tqdm\n",
    "\n",
    "from src.embeddings.vector_store import load_index, get_embedder\n",
    "from src.ingestion.pdf_loader import load_all_documents\n",
    "from src.ingestion.chunker import pages_to_langchain_docs, chunk_documents\n",
    "\n",
    "sns.set_theme(style='darkgrid')\n",
    "print('Loading data...')\n",
    "vs = load_index()\n",
    "pages = load_all_documents(data_dir='data/raw')\n",
    "docs = pages_to_langchain_docs(pages)\n",
    "chunks = chunk_documents(docs)\n",
    "print(f'Loaded {len(chunks)} chunks')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Extract Embeddings from FAISS Index"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Extracted 2000 embeddings directly from FAISS\n",
      "Embedding shape: (2000, 768)\n",
      "Unique sources: {'faa_powerplant', 'faa_general', 'faa_airframe'}\n"
     ]
    }
   ],
   "source": [
    "import numpy as np\n",
    "import random\n",
    "\n",
    "# Extract embeddings directly from FAISS index — no re-embedding needed\n",
    "random.seed(42)\n",
    "sample_size = min(2000, vs.index.ntotal)\n",
    "sample_idx = random.sample(range(vs.index.ntotal), sample_size)\n",
    "\n",
    "# Reconstruct vectors directly from FAISS index\n",
    "embeddings = np.array([vs.index.reconstruct(i) for i in sample_idx])\n",
    "print(f'Extracted {len(embeddings)} embeddings directly from FAISS')\n",
    "print(f'Embedding shape: {embeddings.shape}')\n",
    "\n",
    "# Get corresponding metadata\n",
    "sources = []\n",
    "for i in sample_idx:\n",
    "    doc_id = vs.index_to_docstore_id[i]\n",
    "    doc = vs.docstore.search(doc_id)\n",
    "    sources.append(doc.metadata['source'])\n",
    "\n",
    "print(f'Unique sources: {set(sources)}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. UMAP Dimensionality Reduction"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Running UMAP...\n"
     ]
    },
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "c:\\Users\\Karthik\\Desktop\\Projects\\aeromanual-rag\\venv\\lib\\site-packages\\umap\\umap_.py:1952: UserWarning: n_jobs value 1 overridden to 1 by setting random_state. Use no seed for parallelism.\n",
      "  warn(\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "UMAP output shape: (2000, 2)\n"
     ]
    }
   ],
   "source": [
    "# Install umap if needed: pip install umap-learn\n",
    "try:\n",
    "    import umap\n",
    "except ImportError:\n",
    "    os.system('pip install umap-learn -q')\n",
    "    import umap\n",
    "\n",
    "print('Running UMAP...')\n",
    "reducer = umap.UMAP(n_components=2, random_state=42, n_neighbors=15, min_dist=0.1)\n",
    "embedding_2d = reducer.fit_transform(embeddings)\n",
    "print(f'UMAP output shape: {embedding_2d.shape}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Visualize by Document Source"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1200x800 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Saved to data/processed/umap_by_source.png\n"
     ]
    }
   ],
   "source": [
    "df_umap = pd.DataFrame({\n",
    "    'x': embedding_2d[:, 0],\n",
    "    'y': embedding_2d[:, 1],\n",
    "    'source': sources\n",
    "})\n",
    "\n",
    "plt.figure(figsize=(12, 8))\n",
    "palette = {'faa_powerplant': '#e74c3c', 'faa_airframe': '#3498db', 'faa_general': '#2ecc71'}\n",
    "for source, color in palette.items():\n",
    "    mask = df_umap['source'] == source\n",
    "    plt.scatter(df_umap[mask]['x'], df_umap[mask]['y'],\n",
    "                c=color, label=source, alpha=0.5, s=10)\n",
    "\n",
    "plt.title('UMAP Visualization of Chunk Embeddings by Document', fontsize=14)\n",
    "plt.legend(markerscale=3)\n",
    "plt.xlabel('UMAP Dimension 1')\n",
    "plt.ylabel('UMAP Dimension 2')\n",
    "plt.tight_layout()\n",
    "plt.savefig('data/processed/umap_by_source.png', dpi=150)\n",
    "plt.show()\n",
    "print('Saved to data/processed/umap_by_source.png')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Query Similarity in Embedding Space"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1200x800 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "# Embed test queries and show where they land in the space\n",
    "test_queries = [\n",
    "    'turbine engine inspection',\n",
    "    'fuel system safety',\n",
    "    'hydraulic system maintenance',\n",
    "    'magneto timing'\n",
    "]\n",
    "query_embeddings = embedder.embed_documents(test_queries)\n",
    "query_2d = reducer.transform(np.array(query_embeddings))\n",
    "\n",
    "plt.figure(figsize=(12, 8))\n",
    "for source, color in palette.items():\n",
    "    mask = df_umap['source'] == source\n",
    "    plt.scatter(df_umap[mask]['x'], df_umap[mask]['y'],\n",
    "                c=color, label=source, alpha=0.3, s=8)\n",
    "\n",
    "# Plot query points\n",
    "colors = ['gold', 'orange', 'red', 'purple']\n",
    "for i, (q, qe) in enumerate(zip(test_queries, query_2d)):\n",
    "    plt.scatter(qe[0], qe[1], c=colors[i], s=200, marker='*',\n",
    "                label=f'Query: {q}', zorder=5, edgecolors='black', linewidth=0.5)\n",
    "\n",
    "plt.title('Query Positions in Embedding Space', fontsize=14)\n",
    "plt.legend(markerscale=1, fontsize=8, loc='best')\n",
    "plt.tight_layout()\n",
    "plt.savefig('data/processed/umap_queries.png', dpi=150)\n",
    "plt.show()"
   ]
  }
 ],
